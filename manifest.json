{
  "manifest_version": 3,
  "name": "QuickFill — Profile Autofill",
  "version": "1.0.0",
  "description": "Save multiple personal profiles and autofill forms (job portals, signups, etc.) with one click.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QuickFill",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "fill-active-profile": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Fill the current page with the active profile"
    }
  }
}
